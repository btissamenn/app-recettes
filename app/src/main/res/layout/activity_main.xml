<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="80dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER with gradient background -->
            <LinearLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_header_gradient"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="48dp"
                android:paddingBottom="24dp">

                <!-- Greeting row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvGreetingSmall"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bonjour 👋"
                            android:textSize="13sp"
                            android:textColor="@color/text_secondary"
                            android:textStyle="bold"
                            android:layout_marginBottom="2dp"/>

                        <TextView
                            android:id="@+id/tvGreetingName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Yasmine !"
                            android:textSize="34sp"
                            android:textColor="@color/text_dark"
                            android:fontFamily="serif"/>

                    </LinearLayout>

                    <!-- Avatar circle -->
                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="46dp"
                        android:layout_height="46dp"
                        android:text="YS"
                        android:textColor="@color/white"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:background="@drawable/bg_avatar"/>

                </LinearLayout>

                <!-- Search bar -->
                <LinearLayout
                    android:id="@+id/searchBar"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_search"
                    android:elevation="4dp">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_search"
                        app:tint="@color/green_light"/>

                    <EditText
                        android:id="@+id/etSearch"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_marginStart="10dp"
                        android:hint="Rechercher une recette…"
                        android:textColorHint="@color/text_hint"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:background="@null"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:singleLine="true"/>

                </LinearLayout>

            </LinearLayout>

            <!-- CATEGORY PILLS -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="16dp"
                android:paddingBottom="8dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/categoryContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/catTout"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Tout"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_cat_active"/>

                    <TextView
                        android:id="@+id/catEntrees"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Entrées"
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_cat_inactive_text"/>

                    <TextView
                        android:id="@+id/catPlats"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Plats"
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_cat_inactive_text"/>

                    <TextView
                        android:id="@+id/catDesserts"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Desserts"
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_cat_inactive_text"/>

                    <TextView
                        android:id="@+id/catBoissons"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:text="Boissons"
                        android:textColor="#555555"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:paddingStart="20dp"
                        android:paddingEnd="20dp"
                        android:background="@drawable/bg_cat_inactive_text"/>

                </LinearLayout>
            </HorizontalScrollView>
            <!-- SECTION TITLE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="22dp"
                android:paddingBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mes Recettes"
                    android:textSize="20sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="serif"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvVoirTout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voir tout"
                    android:textSize="12sp"
                    android:textColor="@color/green_main"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- STAGGERED GRID via two columns -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:gravity="top">

                <!-- Left column -->
                <LinearLayout
                    android:id="@+id/columnLeft"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="7dp"/>

                <!-- Right column (offset down) -->
                <LinearLayout
                    android:id="@+id/columnRight"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="7dp"
                    android:layout_marginTop="40dp"/>



            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- BOTTOM NAVIGATION -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="@color/white"
        app:menu="@menu/bottom_nav_menu"
        app:itemIconTint="@drawable/nav_selector"
        app:itemTextColor="@drawable/nav_selector"
        app:itemRippleColor="@color/green_wash"
        app:labelVisibilityMode="labeled"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>